# ─── TXENT Configuration ───────────────────────────────────────
# Copy this file to .env and fill in your values

# ─── LLM Configuration ────────────────────────────────────────
# Any OpenAI-compatible endpoint (local or cloud)
LLM_URL=http://localhost:8001/v1/chat/completions
LLM_MODEL=meta-llama/Meta-Llama-3-8B-Instruct

# ─── TXENT Core Settings ──────────────────────────────────────
KICK_THRESHOLD=0.42
API_PORT=8000
EMBEDDING_MODEL=all-mpnet-base-v2

# ─── Memory Persistence ──────────────────────────────────────
DREAMWEAVE_MEMORY_DIR=memory_store
DREAMWEAVE_AUTO_LOAD=true
DREAMWEAVE_AUTO_SAVE=true

# ─── Splunk Enterprise REST API ──────────────────────────────
# Your Splunk Enterprise management host (e.g., localhost or 192.168.1.x)
SPLUNK_HOST=localhost
# Splunk authentication token (Settings > Tokens in Splunk Web)
SPLUNK_TOKEN=
# Splunk management port (default: 8089)
SPLUNK_PORT=8089

# ─── Splunk MCP Server ──────────────────────────────────────
# URL of the Splunk MCP Server app (Splunkbase #7931)
# Typically: http://localhost:8089/services/mcp
SPLUNK_MCP_URL=

# ─── Splunk HTTP Event Collector (HEC) ──────────────────────
# For pushing TXENT investigation results back to Splunk
SPLUNK_HEC_URL=https://localhost:8088/services/collector/event
SPLUNK_HEC_TOKEN=

# ─── Optional AI API Keys ───────────────────────────────────
GEMINI_API_KEY=
OPENAI_API_KEY=

# ─── Testing ────────────────────────────────────────────────
CI=false
