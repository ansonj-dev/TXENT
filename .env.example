# ─── TXENT Configuration ───────────────────────────────────────
# Copy this file to .env and fill in your values

# ─── LLM Configuration ────────────────────────────────────────
# Option A: Use a cloud model (No GPU or local LLM server needed!)
# Simply add one of the keys below:
GEMINI_API_KEY=
# OPENAI_API_KEY=

# Option B: Use any OpenAI-compatible local endpoint (e.g., vLLM or Ollama)
# LLM_URL=http://localhost:8001/v1/chat/completions
# LLM_MODEL=meta-llama/Meta-Llama-3-8B-Instruct

# ─── TXENT Core Settings ──────────────────────────────────────
KICK_THRESHOLD=0.42
API_PORT=8000
EMBEDDING_MODEL=all-mpnet-base-v2

# ─── Memory Persistence ──────────────────────────────────────
TXENT_MEMORY_DIR=memory_store
TXENT_AUTO_LOAD=true
TXENT_AUTO_SAVE=true

# ─── Splunk Enterprise REST API ──────────────────────────────
# Your Splunk Enterprise management host (host/IP or full https://host:8089 URL)
SPLUNK_HOST=localhost
# Splunk authentication token (Settings > Tokens in Splunk Web)
SPLUNK_TOKEN=
# Splunk management port (default: 8089)
SPLUNK_PORT=8089

# ─── Splunk MCP Server ──────────────────────────────────────
# URL of the Splunk MCP Server app (Splunkbase #7931)
# Typically: http://localhost:8089/services/mcp
SPLUNK_MCP_URL=
SPLUNK_MCP_TOKEN=

# ─── Splunk HTTP Event Collector (HEC) ──────────────────────
# For pushing TXENT investigation results back to Splunk
SPLUNK_HEC_URL=https://localhost:8088/services/collector/event
SPLUNK_HEC_TOKEN=

# ─── Optional AI API Keys ───────────────────────────────────
GEMINI_API_KEY=
OPENAI_API_KEY=

# ─── Testing ────────────────────────────────────────────────
CI=false
